# -- Dynamic lore + enchantment glint per toggle --
# Note: jreset option uses the .jumpreset toggles scoreboard (not .jreset).
execute in minecraft:overworld if score .jumpreset toggles matches 1 run data modify block -715 31 90 Items[{Slot:0b}].components merge value {"minecraft:enchantment_glint_override":true,"minecraft:lore":[{text:"Current: Enabled",color:"green",italic:false}]}
execute in minecraft:overworld unless score .jumpreset toggles matches 1 run data modify block -715 31 90 Items[{Slot:0b}].components merge value {"minecraft:enchantment_glint_override":false,"minecraft:lore":[{text:"Current: Disabled",color:"red",italic:false}]}
