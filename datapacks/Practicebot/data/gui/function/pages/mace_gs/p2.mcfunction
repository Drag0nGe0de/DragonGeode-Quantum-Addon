# GUI System - Mace General Settings Page 2 (sub-page of page 26)
# Barrel layout: Toggles(0-5), Back(18), Prev(21), Current Page(22)
# Each toggle shows 'Current: Enabled' (green, glinted) or 'Current: Disabled'
# (red, no glint). State is read from the .<name> toggles scoreboard scores.
# Toggle list (slot -> function / display name / icon):
#   0  jreset        / Jump Reset       / slime_block   (.jumpreset toggles)
#   1  axe           / Axe              / diamond_axe
#   2  breach        / Breach Swap      / mace
#   3  no_pearl_land / No Pearl Land    / ender_eye
#   4  stap          / S-Tap            / minecart
#   5  shieldcd      / Shield Cooldown  / clock

execute in minecraft:overworld run data merge block -715 31 90 {Items:[{Slot:0b,id:"minecraft:slime_block",count:1,components:{"minecraft:item_name":{text:"Jump Reset",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_jreset"}}},{Slot:1b,id:"minecraft:diamond_axe",count:1,components:{"minecraft:item_name":{text:"Axe",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_axe"}}},{Slot:2b,id:"minecraft:mace",count:1,components:{"minecraft:item_name":{text:"Breach Swap",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_breach"}}},{Slot:3b,id:"minecraft:ender_eye",count:1,components:{"minecraft:item_name":{text:"No Pearl Land",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_no_pearl_land"}}},{Slot:4b,id:"minecraft:minecart",count:1,components:{"minecraft:item_name":{text:"S-Tap",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_stap"}}},{Slot:5b,id:"minecraft:clock",count:1,components:{"minecraft:item_name":{text:"Shield Cooldown",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_shieldcd"}}},{Slot:6b,id:"minecraft:gray_stained_glass_pane",count:1,components:{"minecraft:item_name":{text:"",italic:false},"minecraft:tooltip_display":{hide_tooltip:true},"minecraft:custom_data":{gui_btn:"filler"}}},{Slot:7b,id:"minecraft:gray_stained_glass_pane",count:1,components:{"minecraft:item_name":{text:"",italic:false},"minecraft:tooltip_display":{hide_tooltip:true},"minecraft:custom_data":{gui_btn:"filler"}}},{Slot:8b,id:"minecraft:gray_stained_glass_pane",count:1,components:{"minecraft:item_name":{text:"",italic:false},"minecraft:tooltip_display":{hide_tooltip:true},"minecraft:custom_data":{gui_btn:"filler"}}},{Slot:9b,id:"minecraft:gray_stained_glass_pane",count:1,components:{"minecraft:item_name":{text:"",italic:false},"minecraft:tooltip_display":{hide_tooltip:true},"minecraft:custom_data":{gui_btn:"filler"}}},{Slot:10b,id:"minecraft:gray_stained_glass_pane",count:1,com