# GUI System - Mace General Settings Page 1 (sub-page of page 26)
# Reached from Play -> Settings -> General Settings when .gm = 3 (Mace).
# Barrel layout: Toggles(0-17), Back(18), Current Page(22), Next(23)
# Each toggle shows 'Current: Enabled' (green, glinted) or 'Current: Disabled'
# (red, no glint). State is read from the .<name> toggles scoreboard scores.
# Toggle list (slot -> function / display name / icon):
#   0  no_fall      / No Fall Damage   / hay_block
#   1  stun         / Stunning         / netherite_axe (gold_nugget+item_model)
#   2  refill       / Refill Items     / cauldron
#   3  pcrit        / Punish Crit      / cactus
#   4  cobweb       / Cobweb           / cobweb
#   5  small        / Small Bot        / turtle_egg
#   6  crit         / Crit             / fire_charge
#   7  buffs        / Buffs            / splash_potion (light blue, via gold_nugget+item_model)
#   8  shield       / Shield           / shield (gold_nugget+item_model)
#   9  wind_pearl   / Wind Pearl       / wind_charge
#  10  elytra       / Elytra           / elytra (gold_nugget+item_model)
#  11  strafe       / Strafe           / magenta_glazed_terracotta
#  12  random       / Random Playstyle / chorus_fruit
#  13  spear        / Spear            / netherite_spear (gold_nugget+item_model, mod item)
#  14  far_pearl    / Far Pearl        / ender_pearl
#  15  breakable    / Breakable Armor  / cracked_stone_bricks (gold_nugget+item_model)
#  16  resistance   / Resistance       / turtle_helmet (gold_nugget+item_model)
#  17  water        / Water            / water_bucket

execute in minecraft:overworld run data merge block -715 31 90 {Items:[{Slot:0b,id:"minecraft:hay_block",count:1,components:{"minecraft:item_name":{text:"No Fall Damage",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_no_fall"}}},{Slot:1b,id:"minecraft:gold_nugget",count:1,components:{"minecraft:item_model":"minecraft:netherite_axe","minecraft:item_name":{text:"Stunning",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_stun"}}},{Slot:2b,id:"minecraft:cauldron",count:1,components:{"minecraft:item_name":{text:"Refill Items",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_refill"}}},{Slot:3b,id:"minecraft:cactus",count:1,components:{"minecraft:item_name":{text:"Punish Crit",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_pcrit"}}},{Slot:4b,id:"minecraft:cobweb",count:1,components:{"minecraft:item_name":{text:"Cobweb",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_cobweb"}}},{Slot:5b,id:"minecraft:turtle_egg",count:1,components:{"minecraft:item_name":{text:"Small Bot",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_small"}}},{Slot:6b,id:"minecraft:fire_charge",count:1,components:{"minecraft:item_name":{text:"Crit",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_crit"}}},{Slot:7b,id:"minecraft:gold_nugget",count:1,components:{"minecraft:item_model":"minecraft:splash_potion","minecraft:tooltip_display":{"hidden_components":["minecraft:potion_contents"]},"minecraft:custom_data":{gui_btn:"mace_gs_buffs"},"minecraft:potion_contents":{"custom_color":6744063}}},{Slot:8b,id:"minecraft:gold_nugget",count:1,components:{"minecraft:item_model":"minecraft:shield","minecraft:item_name":{text:"Shield",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_shield"}}},{Slot:9b,id:"minecraft:wind_charge",count:1,components:{"minecraft:item_name":{text:"Wind Pearl",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_wind_pearl"}}},{Slot:10b,id:"minecraft:gold_nugget",count:1,components:{"minecraft:item_model":"minecraft:elytra","minecraft:item_name":{text:"Elytra",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_elytra"}}},{Slot:11b,id:"minecraft:magenta_glazed_terracotta",count:1,components:{"minecraft:item_name":{text:"Strafe",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_strafe"}}},{Slot:12b,id:"minecraft:chorus_fruit",count:1,components:{"minecraft:item_name":{text:"Random Playstyle",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_random"}}},{Slot:13b,id:"minecraft:gold_nugget",count:1,components:{"minecraft:item_model":"minecraft:netherite_spear","minecraft:item_name":{text:"Spear",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_spear"}}},{Slot:14b,id:"minecraft:ender_pearl",count:1,components:{"minecraft:item_name":{text:"Far Pearl",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_far_pearl"}}},{Slot:15b,id:"minecraft:gold_nugget",count:1,components:{"minecraft:item_model":"minecraft:cracked_stone_bricks","minecraft:item_name":{text:"Breakable Armor",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_breakable"}}},{Slot:16b,id:"minecraft:gold_nugget",count:1,components:{"minecraft:item_model":"minecraft:turtle_helmet","minecraft:item_name":{text:"Resistance",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_resistance"}}},{Slot:17b,id:"minecraft:water_bucket",count:1,components:{"minecraft:item_name":{text:"Water",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_water"}}},{Slot:18b,id:"minecraft:feather",count:1,components:{"minecraft:item_name":{text:"Back",italic:false},"minecraft:tooltip_display":{"hidden_components":["minecraft:lore"]},"minecraft:custom_data":{gui_btn:"back"}}},{Slot:19b,id:"minecraft:gray_stained_glass_pane",count:1,components:{"minecraft:item_name":{text:"",italic:false},"minecraft:tooltip_display":{hide_tooltip:true},"minecraft:custom_data":{gui_btn:"filler"}}},{Slot:20b,id:"minecraft:gray_stained_glass_pane",count:1,components:{"minecraft:item_name":{text:"",italic:false},"minecraft:tooltip_display":{hide_tooltip:true},"minecraft:custom_data":{gui_btn:"filler"}}},{Slot:21b,id:"minecraft:gray_stained_glass_pane",count:1,components:{"minecraft:item_name":{text:"",italic:false},"minecraft:tooltip_display":{hide_tooltip:true},"minecraft:custom_data":{gui_btn:"filler"}}},{Slot:22b,id:"minecraft:nether_star",count:1,components:{"minecraft:item_name":{text:"Mace General Settings",color:"gold",italic:false},"minecraft:lore":[{text:"Page 1 of 2",color:"gray",italic:false}],"minecraft:custom_data":{gui_btn:"mace_gs_pageinfo"}}},{Slot:23b,id:"minecraft:arrow",count:1,components:{"minecraft:item_name":{text:"Next Page",color:"yellow",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_next"}}},{Slot:24b,id:"minecraft:gray_stained_glass_pane",count:1,components:{"minecraft:item_name":{text:"",italic:false},"minecraft:tooltip_display":{hide_tooltip:true},"minecraft:custom_data":{gui_btn:"filler"}}},{Slot:25b,id:"minecraft:gray_stained_glass_pane",count:1,components:{"minecraft:item_name":{text:"",italic:false},"minecraft:tooltip_display":{hide_tooltip:true},"minecraft:custom_data":{gui_btn:"filler"}}},{Slot:26b,id:"minecraft:gray_stained_glass_pane",count:1,components:{"minecraft:item_name":{text:"",italic:false},"minecraft:tooltip_display":{hide_tooltip:true},"minecraft:custom_data":{gui_btn:"filler"}}}]}

# Buffs (slot 7) uses the splash_potion model on a gold_nugget base. splash_potion
# has a default item_name that overrides the item_name component, so we set the
# custom_name via item modify (same trick as the Pot gamemode button).
execute in minecraft:overworld run item modify block -715 31 90 container.7 {"function":"minecraft:set_name","target":"custom_name","name":{"text":"Buffs","color":"aqua","italic":false}}

# -- Dynamic lore + enchantment glint per toggle --
execute in minecraft:overworld if score .no_fall toggles matches 1 run data modify block -715 31 90 Items[{Slot:0b}].components merge value {"minecraft:enchantment_glint_override":true,"minecraft:lore":[{text:"Current: Enabled",color:"green",italic:false}]}
execute in minecraft:overworld unless score .no_fall toggles matches 1 run data modify block -715 31 90 Items[{Slot:0b}].components merge value {"minecraft:enchantment_glint_override":false,"minecraft:lore":[{text:"Current: Disabled",color:"red",italic:false}]}
