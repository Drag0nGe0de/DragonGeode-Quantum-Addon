# Mirror bot reach into a fake-player score for matching.
# If the bot hasn't spawned yet (or reach unset), default to 28 (2.8 blocks).
scoreboard players set .adv_reach var 0
execute store result score .adv_reach var run scoreboard players get @a[tag=xlib_bot,limit=1] reach
execute unless score .adv_reach var matches 1..255 run scoreboard players set .adv_reach var 28

# Per-option glint + lore
execute in minecraft:overworld if score .adv_reach var matches 14 run data modify block -715 31 90 Items[{Slot:0b}].components merge value {"minecraft:enchantment_glint_override":true,"minecraft:lore":[{text:"Current",color:"green",italic:false}]}
execute in minecraft:overworld unless score .adv_reach var matches 14 run data modify block -715 31 90 Items[{Slot:0b}].components merge value {"minecraft:enchantment_glint_override":false,"minecraft:lore":[{text:"Click to select",color:"gray",italic:false}]}
