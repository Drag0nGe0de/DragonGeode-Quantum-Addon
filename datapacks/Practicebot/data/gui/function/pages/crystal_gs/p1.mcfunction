# GUI System - Crystal General Settings Page 1 (sub-page of page 27)
# Reached from Play -> Settings -> General Settings when .gm = 4 (Crystal).
# Barrel layout: Toggles(0-17), Back(18), Current Page(22), Next(23)
# Each toggle shows 'Current: Enabled' (green, glinted) or 'Current: Disabled'
# (red, no glint). State is read from the .<name> toggles scoreboard scores.
# Slot 14 (Playstyle) is special: it toggles between Ledge Spammer (.crystal_playstyle=1)
# and Anchor Spammer (.crystal_playstyle=2). Icon and lore swap based on the
# current value; the glint override does not apply.
#
# Armor / weapon / tool icons are rendered on a gold_nugget base with an
# item_model override, so the player can't actually equip or swing them if the
# GUI item briefly lands in their inventory. This mirrors the mace_gs page.
#
# Toggle list (slot -> function / display name / icon):
#   0  stun              / Stunning             / netherite_axe (gold_nugget+item_model)
#   1  strafe            / Strafe               / magenta_glazed_terracotta
#   2  blocks_drop       / Blocks Drop          / campfire
#   3  refill            / Refill Items         / cauldron
#   4  axe               / Axe                  / diamond_axe (gold_nugget+item_model)
#   5  small             / Small Bot            / turtle_egg
#   6  cobweb            / Cobweb               / cobweb
#   7  buffs             / Buffs                / splash_potion (gold_nugget+item_model, custom_name via item modify)
#   8  shield            / Shield               / shield (gold_nugget+item_model)
#   9  holding           / Keep Pressure        / iron_chain
#  10  slowfall          / Permanent Slowfall   / feather
#  11  crystals          / Use Crystals         / end_crystal
#  12  anchors           / Use Anchors          / respawn_anchor
#  13  better_npc_shield / NPC Shield+          / shield (gold_nugget+item_model, distinct gui_btn)
#  14  crystal_playstyle / Playstyle            / end_crystal OR respawn_anchor (dynamic; see below)
#  15  dbp               / Double Blast Protection / netherite_boots (gold_nugget+item_model)
#  16  inf_tot           / Infinite Totems      / totem_of_undying
#  17  oldkb             / Old Explosions KB    / netherite_leggings (gold_nugget+item_model)

execute in minecraft:overworld run data merge block -715 31 90 {Items:[{Slot:0b,id:"minecraft:gold_nugget",count:1,components:{"minecraft:item_model":"minecraft:netherite_axe","minecraft:item_name":{text:"Stunning",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"crystal_gs_stun"}}},{Slot:1b,id:"minecraft:magenta_glazed_terracotta",count:1,components:{"minecraft:item_name":{text:"Strafe",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"crystal_gs_strafe"}}},{Slot:2b,id:"minecraft:campfire",count:1,components:{"minecraft:item_name":{text:"Blocks Drop",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"crystal_gs_blocks_drop"}}},{Slot:3b,id:"minecraft:cauldron",count:1,components:{"minecraft:item_name":{text:"Refill Items",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"crystal_gs_refill"}}},{Slot:4b,id:"minecraft:gold_nugget",count:1,components:{"minecraft:item_model":"minecraft:diamond_axe","minecraft:item_name":{text:"Axe",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"crystal_gs_axe"}}},{Slot:5b,id:"minecraft:turtle_egg",count:1,components:{"minecraft:item_name":{text:"Small Bot",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"crystal_gs_small"}}},{Slot:6b,id:"minecraft:cobweb",count:1,components:{"minecraft:item_name":{text:"Cobweb",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"crystal_gs_cobweb"}}},{Slot:7b,id:"minecraft:gold_nugget",count:1,components:{"minecraft:item_model":"minecraft:splash_potion","minecraft:tooltip_display":{"hidden_components":["minecraft:potion_contents"]},"minecraft:custom_data":{gui_btn:"crystal_gs_buffs"},"minecraft:potion_contents":{"custom_color":6744063}}},{Slot:8b,id:"minecraft:gold_nugget",count:1,components:{"minecraft:item_model":"minecraft:shield","minecraft:item_name":{text:"Shield",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"crystal_gs_shield"}}},{Slot:9b,id:"minecraft:iron_chain",count:1,components:{"minecraft:item_name":{text:"Keep Pressure",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"crystal_gs_holding"}}},{Slot:10b,id:"minecraft:feather",count:1,components:{"minecraft:item_name":{text:"Permanent Slowfall",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"crystal_gs_slowfall"}}},{Slot:11b,id:"minecraft:end_crystal",count:1,components:{"minecraft:item_name":{text:"Use Crystals",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"crystal_gs_crystals"}}},{Slot:12b,id:"minecraft:respawn_anchor",count:1,components:{"minecraft:item_name":{text:"Use Anchors",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"crystal_gs_anchors"}}},{Slot:13b,id:"minecraft:gold_nugget",count:1,components:{"minecraft:item_model":"minecraft:shield","minecraft:item_name":{text:"NPC Shield+",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"crystal_gs_better_npc_shield"}}},{Slot:14b,id:"minecraft:end_crystal",count:1,components:{"minecraft:item_name":{text:"Playstyle",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"crystal_gs_playstyle"}}},{Slot:15b,id:"minecraft:gold_nugget",count:1,components:{"minecraft:item_model":"minecraft:netherite_boots","minecraft:item_name":{text:"Double Blast Protection",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"crystal_gs_dbp"}}},{Slot:16b,id:"minecraft:totem_of_undying",count:1,components:{"minecraft:item_name":{text:"Infinite Totems",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"crystal_gs_inf_tot"}}},{Slot:17b,id:"minecraft:gold_nugget",count:1,components:{"minecraft:item_model":"minecraft:netherite_leggings","minecraft:item_name":{text:"Old Explosions KB",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"crystal_gs_oldkb"}}},{Slot:18b,id:"minecraft:feather",count:1,components:{"minecraft:item_name":{text:"Back",italic:false},"minecraft:tooltip_display":{"hidden_components":["minecraft:lore"]},"minecraft:custom_data":{gui_btn:"back"}}},{Slot:19b,id:"minecraft:gray_stained_glass_pane",count:1,components:{"minecraft:item_name":{text:"",italic:false},"minecraft:tooltip_display":{hide_tooltip:true},"minecraft:custom_data":{gui_btn:"filler"}}},{Slot:20b,id:"minecraft:gray_stained_glass_pane",count:1,components:{"minecraft:item_name":{text:"",italic:false},"minecraft:tooltip_display":{hide_tooltip:true},"minecraft:custom_data":{gui_btn:"filler"}}},{Slot:21b,id:"minecraft:gray_stained_glass_pane",count:1,components:{"minecraft:item_name":{text:"",italic:false},"minecraft:tooltip_display":{hide_tooltip:true},"minecraft:custom_data":{gui_btn:"filler"}}},{Slot:22b,id:"minecraft:nether_star",count:1,components:{"minecraft:item_name":{text:"Crystal General Settings",color:"gold",italic:false},"minecraft:lore":[{text:"Page 1 of 2",color:"gray",italic:false}],"minecraft:custom_data":{gui_btn:"crystal_gs_pageinfo"}}},{Slot:23b,id:"minecraft:arrow",count:1,components:{"minecraft:item_name":{text:"Next Page",color:"yellow",italic:false},"minecraft:custom_data":{gui_btn:"crystal_gs_next"}}},{Slot:24b,id:"minecraft:gray_stained_glass_pane",count:1,components:{"minecraft:item_name":{text:"",italic:false},"minecraft:tooltip_display":{hide_tooltip:true},"minecraft:custom_data":{gui_btn:"filler"}}},{Slot:25b,id:"minecraft:gray_stained_glass_pane",count:1,components:{"minecraft:item_name":{text:"",italic:false},"minecraft:tooltip_display":{hide_tooltip:true},"minecraft:custom_data":{gui_btn:"filler"}}},{Slot:26b,id:"minecraft:gray_stained_glass_pane",count:1,components:{"minecraft:item_name":{text:"",italic:false},"minecraft:tooltip_display":{hide_tooltip:true},"minecraft:custom_data":{gui_btn:"filler"}}}]}

# Buffs (slot 7) uses the splash_potion model on a gold_nugget base. splash_potion
# has a default item_name that overrides the item_name component, so we set the
# custom_name via item modify (same trick as the Mace page and Pot gamemode button).
execute in minecraft:overworld run item modify block -715 31 90 container.7 {"function":"minecraft:set_name","target":"custom_name","name":{"text":"Buffs","color":"aqua","italic":false}}

# -- Playstyle (slot 14): dynamic icon + lore based on .crystal_playstyle --
# Default (unset or 1) = Ledge Spammer (end_crystal icon, "Ledge Spammer" green).
# 2 = Anchor Spammer (respawn_anchor icon, "Anchor Spammer" green).
execute in minecraft:overworld unless score .crystal_playstyle toggles matches 2 run data modify block -715 31 90 Items[{Slot:14b}].id set value "minecraft:end_crystal"
execute in minecraft:overworld unless score .crystal_playstyle toggles matches 2 run data modify block -715 31 90 Items[{Slot:14b}].components."minecraft:lore" set value [{text:"> Ledge Spammer",color:"green",italic:false},{text:"> Anchor Spammer",color:"gray",italic:false},{text:"Click to toggle playstyle.",color:"gray",italic:false}]
execute in minecraft:overworld if score .crystal_playstyle toggles matches 2 run data modify block -715 31 90 Items[{Slot:14b}].id set value "minecraft:respawn_anchor"
execute in minecraft:overworld if score .crystal_playstyle toggles matches 2 run data modify block -715 31 90 Items[{Slot:14b}].components."minecraft:lore" set value [{text:"> Ledge Spammer",color:"gray",italic:false},{text:"> Anchor Spammer",color:"green",italic:false},{text:"Click to toggle playstyle.",color:"gray",italic:false}]

# -- Dynamic lore + enchantment glint per toggle --
execute in minecraft:overworld if score .stun toggles matches 1 run data modify block -715 31 90 Items[{Slot:0b}].components merge value {"minecraft:enchantment_glint_override":true,"minecraft:lore":[{text:"Current: Enabled",color:"green",italic:false}]}
execute in minecraft:overworld unless score .stun toggles matches 1 run data modify block -715 31 90 Items[{Slot:0b}].components merge value {"minecraft:enchantment_glint_override":false,"minecraft:lore":[{text:"Current: Disabled",color:"red",italic:false}]}
