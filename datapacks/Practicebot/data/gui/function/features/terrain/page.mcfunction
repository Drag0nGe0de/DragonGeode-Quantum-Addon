# -- Dynamic Flat Terrain lore (slot 4) based on .flat_terrain toggles --
# .flat_terrain toggles: 1 = enabled, 0 (or unset) = disabled.
# Lore line is "Current: Enabled" (green) or "Current: Disabled" (red)
# so the player can see the live state at a glance. Re-evaluated every
# tick (this page function runs every tick while a player is nearby), so
# manual /function quantum:options/flat_terrain runs also get reflected.
execute in minecraft:overworld if score .flat_terrain toggles matches 1 run data modify block -715 31 90 Items[{Slot:4b}].components."minecraft:lore" set value [{text:"Current: Enabled",color:"green",italic:false}]
execute in minecraft:overworld unless score .flat_terrain toggles matches 1 run data modify block -715 31 90 Items[{Slot:4b}].components."minecraft:lore" set value [{text:"Current: Disabled",color:"red",italic:false}]

scoreboard players set .gui gui_page 5
function gui:core/sync_barrels
