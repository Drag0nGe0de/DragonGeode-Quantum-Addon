# -- Undertale Music (slot 12): glint + "Selected" lore when .music toggles = 1 --
execute in minecraft:overworld if score .music toggles matches 1 run data modify block -715 31 90 Items[{Slot:12b}].components merge value {"minecraft:enchantment_glint_override":true,"minecraft:lore":[{text:"Selected",color:"green",italic:false}]}
execute in minecraft:overworld unless score .music toggles matches 1 run data modify block -715 31 90 Items[{Slot:12b}].components merge value {"minecraft:enchantment_glint_override":false,"minecraft:lore":[]}

