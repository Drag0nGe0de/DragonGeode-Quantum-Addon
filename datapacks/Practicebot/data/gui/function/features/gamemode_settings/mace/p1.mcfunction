# GUI System - Mace General Settings Page 1 (sub-page of page 26)
# Reached from Play -> Settings -> General Settings when .gm = 3 (Mace).
# Barrel layout: Toggles(0-17), Back(18), Current Page(22), Next(23)
# Each toggle shows 'Current: Enabled' (green, glinted) or 'Current: Disabled'
# (red, no glint). State is read from the .<name> toggles scoreboard scores.
#
# Page 1 — Gear & Movement / Defense / Combat Techniques:
# Toggle list (slot -> function / display name / icon):
#   0  armor        / Armor            / netherite_helmet or diamond_helmet (gold_nugget+item_model, dynamic)
#   1  breach       / Breach Swap      / mace (gold_nugget+item_model)
#   2  spear        / Spear            / netherite_spear (gold_nugget+item_model, mod item)
#   3  wind_pearl   / Wind Pearl       / wind_charge
#   4  elytra       / Elytra           / elytra (gold_nugget+item_model)
#   5  far_pearl    / Far Pearl        / ender_pearl
#   6  no_pearl_land / No Pearl Land   / ender_eye
#   7  cobweb       / Cobweb           / cobweb
#   8  water        / Water            / water_bucket
#   9  no_fall      / No Fall Damage   / hay_block
#  10  stun         / Stunning         / netherite_axe (gold_nugget+item_model)
#  11  pcrit        / Punish Crit      / cactus
#  12  crit         / Crit             / fire_charge
#  13  strafe       / Strafe           / magenta_glazed_terracotta
#  14  stap         / S-tap            / minecart
#  15  jreset       / Jump Reset       / slime_block   (.jumpreset toggles)
#  16  shield       / Shield           / shield (gold_nugget+item_model)
#  17  shieldcd     / Shield Cooldown  / clock

execute in minecraft:overworld run data merge block -715 31 90 {Items:[{Slot:0b,id:"minecraft:gold_nugget",count:1,components:{"minecraft:item_model":"minecraft:netherite_helmet","minecraft:item_name":{text:"Armor",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_armor"}}},{Slot:1b,id:"minecraft:gold_nugget",count:1,components:{"minecraft:item_model":"minecraft:mace","minecraft:item_name":{text:"Breach Swap",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_breach"}}},{Slot:2b,id:"minecraft:gold_nugget",count:1,components:{"minecraft:item_model":"minecraft:netherite_spear","minecraft:item_name":{text:"Spear",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_spear"}}},{Slot:3b,id:"minecraft:wind_charge",count:1,components:{"minecraft:item_name":{text:"Wind Pearl",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_wind_pearl"}}},{Slot:4b,id:"minecraft:gold_nugget",count:1,components:{"minecraft:item_model":"minecraft:elytra","minecraft:item_name":{text:"Elytra",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_elytra"}}},{Slot:5b,id:"minecraft:ender_pearl",count:1,components:{"minecraft:item_name":{text:"Far Pearl",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_far_pearl"}}},{Slot:6b,id:"minecraft:ender_eye",count:1,components:{"minecraft:item_name":{text:"No Pearl Land",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_no_pearl_land"}}},{Slot:7b,id:"minecraft:cobweb",count:1,components:{"minecraft:item_name":{text:"Cobweb",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_cobweb"}}},{Slot:8b,id:"minecraft:water_bucket",count:1,components:{"minecraft:item_name":{text:"Water",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_gs_water"}}},{Slot:9b,id:"minecraft:hay_block",count:1,components:{"minecraft:item_name":{text:"No Fall Damage",color:"aqua",italic:false},"minecraft:custom_data":{gui_btn:"mace_g